<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permisos de red y localización -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Huerteando"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- LAUNCHER: pantalla de login -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Registro de nuevo usuario -->
        <activity
            android:name=".RegistroActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Pantalla principal: listado de observaciones -->
        <activity
            android:name=".ObservacionesActivity"
            android:exported="false" />

        <!-- Pantalla principal alternativa (con tabs) -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Detalle de una observación -->
        <activity
            android:name=".DetalleObservacionActivity"
            android:exported="false"
            android:parentActivityName=".ObservacionesActivity" />


        <!-- Crear observación (versión alternativa con más campos) -->
        <activity
            android:name=".CrearObservacionActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ObservacionesActivity" />

    </application>

</manifest>