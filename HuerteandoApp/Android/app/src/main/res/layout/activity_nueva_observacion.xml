<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAF7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título de la pantalla -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nueva observación"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/verde_principal"
            android:layout_marginBottom="20dp" />

        <!-- Selector de tipo de observación (RF-17, RF-18) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tipo de observación *"
            android:textSize="13sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerTipoNueva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_spinner"
            android:layout_marginBottom="16dp" />

        <!-- Título (obligatorio) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:hint="Título *">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTituloNueva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:imeOptions="actionNext" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Descripción (opcional) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:hint="Descripción (opcional)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editDescripcionNueva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="3"
                android:maxLines="6" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Nombre tradicional (RF-08, opcional) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:hint="Nombre tradicional o topónimo (opcional)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editNombreTradicionalNueva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapSentences"
                android:imeOptions="actionDone" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Bloque de ubicación GPS (RF-07: latitud/longitud obligatorios) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ubicación *"
            android:textSize="13sp"
            android:textColor="#666666"
            android:layout_marginBottom="6dp" />

        <!-- Muestra las coordenadas obtenidas -->
        <TextView
            android:id="@+id/tvUbicacionInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sin ubicación — pulsa el botón para obtenerla"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnObtenerUbicacion"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:text="📍 Obtener mi ubicación"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/verde_principal"
            app:strokeWidth="1dp" />

        <!-- Error (oculto por defecto) -->
        <TextView
            android:id="@+id/tvErrorNueva"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:textColor="#D32F2F"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- ProgressBar mientras guarda -->
        <ProgressBar
            android:id="@+id/progressGuardar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Botón guardar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardarObservacion"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="24dp"
            android:text="Guardar observación"
            android:textSize="16sp"
            app:backgroundTint="@color/verde_principal" />

    </LinearLayout>
</ScrollView>
