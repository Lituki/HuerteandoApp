<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_spinner.xml — Fondo con borde para los Spinners de filtro.
    Da un aspecto más cuidado que el fondo por defecto del sistema.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#FFFFFF" />

    <stroke
        android:width="1dp"
        android:color="#CCCCCC" />

    <corners android:radius="8dp" />

    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="8dp"
        android:bottom="8dp" />

</shape>
